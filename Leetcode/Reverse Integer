class Solution {
public:
    int reverse(int x) {
        int extractdigit ;
        long long int  reverse = 0; 
        
        if( x >= INT_MAX || x <= INT_MIN){
        	return 0; 
		}
        
        while(x != 0){
        	
        	extractdigit = x % 10; 
        	reverse = reverse*10 + extractdigit; 
        	x/=10; 
        	
		}
        
        if( reverse >= INT_MAX || reverse <= INT_MIN){
        	return 0; 
		}
        return reverse; 
    }
};
