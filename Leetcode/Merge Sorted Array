#include<algorithm>
class Solution {
public:
    void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {
        
        int temp = m ; 
        m+=n; 
        
        for(int i = 0 ; i < n ; i++){
        	
        	nums1[temp+i] = nums2[i];
        	
		}
		sort(nums1.begin(), nums1.end());
        
        
    }
};
