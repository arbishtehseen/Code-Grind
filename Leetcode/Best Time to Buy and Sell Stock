class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int buy = prices[0]; 
        int maxprofit = 0 ; 
        int profit;
        
    for(int i = 0 ; i < prices.size() ; i++){
    	
    	if(buy > prices[i]){
    		buy = prices[i];
		}
		else{
			profit = prices[i] - buy ; 
			
			if(maxprofit < profit){
				maxprofit = profit; 
			}
		}
	}
    
    return maxprofit;
    }
};
