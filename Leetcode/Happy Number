class Solution {
public:
    bool isHappy(int n) {
        unordered_set<int> seen;
        int extractdigit;

        while(n != 1 && seen.count(n) == 0) {
            seen.insert(n);
            
            int sum = 0;
            while(n != 0) {
                extractdigit = n % 10;
                sum += (extractdigit * extractdigit);
                n = n / 10;
            }
            n = sum;
        }

        return n == 1;
    }
};
