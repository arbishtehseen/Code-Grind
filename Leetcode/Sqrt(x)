class Solution {
public:
    int mySqrt(int x) {
        
        if(x == 0){
            return x;
        }
        if(x == 1){
            return x;
        }

        for(long long i = 2 ; i < x ; i++){
            if(i*i == x){
                return i;
            }
            if(i*i > x){
                return i-1; 
            }
        }
        return x-1;
    }
};
