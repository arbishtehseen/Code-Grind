class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double maxavg = INT_MIN;

        for(int i = 0 ; i <= nums.size()-k ; i++){
            double sum = 0.0;
            double average = 0.0;

            for(int j = i ; j < i+k ; j++){
                sum+=nums[j]; 
            }
            average = sum / k ;

            if(maxavg < average){
                maxavg = average;
            }
        }

    return maxavg;

    }
};
