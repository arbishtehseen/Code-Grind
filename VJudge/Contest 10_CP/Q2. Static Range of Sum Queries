#include<iostream>
using namespace std;

int main(){
	int n , q;
	
	cin>>n>>q;
	
	int arr[n+1]; 
	arr[0] = 0; 
	
	long long  pref[n+1];
	
	pref[0] = 0; 
	
	for(int i = 1 ; i <= n ; i++){
		cin>>arr[i]; 
		pref[i] = pref[i-1] + arr[i]; 
	
	}
	
	int a , b; 
	
	for(int i = 1 ; i <= q ; i++){
		cin>>a>>b; 
		
		cout<<pref[b]-pref[a-1]<<endl;
		
		
	}
	
	
	return 0; 
}
