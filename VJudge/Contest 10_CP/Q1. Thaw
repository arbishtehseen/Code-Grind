#include<iostream>
using namespace std;

int main(){
	int n ; 
	
	cin>>n;
	int arr[n];

	for(int i = 0 ; i < n ; i++){
		cin>>arr[i]; 
	}
	
	
	int maximumstreak = 0;
	
	for(int i = 0 ; i < n ; i++){
		int currentstreak = 0;
		
		for(int j = i ; j < n ; j++){
			
			if(arr[j] > 0){
				currentstreak++; 
			}
			else{
				break;
			}
			
		}
		
		if(maximumstreak < currentstreak){
			maximumstreak = currentstreak;
		}
		
	}
	
	
	cout<<maximumstreak;
	
	return 0;
}
