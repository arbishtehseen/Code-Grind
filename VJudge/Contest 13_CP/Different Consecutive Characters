#include<iostream>
#include<string>
using namespace std;

int main(){
	int T; 
	cin>>T;
	
	while(T--){
		int len;
		cin>>len; 
		
		string input;
		cin>>input;
	    
	    int count = 0; 
	    
	    for(int i = 0 ; i < len-1 ; i++){
	    	if(input[i] == input[i+1]){
	    		count++;
			}
		}
		cout<<count<<endl;
	}
	return 0;
}
