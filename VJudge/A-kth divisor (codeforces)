#include<iostream>
#include<cmath>
using namespace std;
int main(){
	
	long long n , k ; 
	cin>>n;
	cin>>k;
	
	int size = 0 ; 
	long long arr[100000];
	
	for(long long i = 1 ; i <= sqrt(n) ; i++){
		
		if(n % i == 0){
			arr[size++] = i ; 
			
			if(i*i != n){
			arr[size++] = n/i;
		}
			
		}
	}
	
	for(long long i = 0 ; i < size-1 ; i++){
		for(long long  j = 0 ; j < size - i - 1 ; j++){
			if(arr[j] > arr[j+1]){
			long long temp = arr[j]; 
			arr[j] = arr[j+1];
			arr[j+1] = temp;
		}
		}
	}
	
	
	
	
	if(k > size){
		cout<<"-1";
	}
	else{
		cout<<arr[k-1];
	}
}
