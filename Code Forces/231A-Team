#include<iostream>
using namespace std;
int main(){
	
	int row; 
	
	cin>>row;
	
	int arr[row][3];
	int problems_solved = 0; 
	
	for(int i = 0; i < row ; i++){
		int count = 0 ; 
		for(int j = 0 ; j < 3 ; j++){
			cin>>arr[i][j]; 
			count+=arr[i][j]; 
		}
		if(count == 2 || count == 3){
			problems_solved++; 
		}
	}
	
	cout<<problems_solved;
	
	return 0;
}
