#include<iostream>
#include<string>
using namespace std;
int main(){
	
	int lines; 
	cin>>lines; 
	int N = lines; 
	int n = 0; 
	
	string s;
	
	for(int i = 0 ; i < N ; i++){
		cin>>s; 
		
		if(s == "X++" ){
			n++; 
		}
		else if(s == "++X"){
			++n; 
		}
		else if( s == "X--"){
			n--;
		}
		else if(s == "--X"){
			--n;
		}
	}
	
	cout<<n;
	
	return 0; 
}
